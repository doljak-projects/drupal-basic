{% set pet_type = fields.field_pet_type.content|striptags|trim|lower|replace({' ': '-'}) %}
{% set product_url = path('entity.node.canonical', {'node': row._entity.id}) %}
{% set badge_text = fields.field_product_badge.content|striptags|trim %}

<article class="shop-card shop-card--{{ pet_type }}">

  <div class="shop-card__image-wrap">
    {% if badge_text is not empty %}
      <span class="shop-card__badge shop-card__badge--{{ badge_text|lower }}">{{ badge_text }}</span>
    {% endif %}
    {{ fields.field_product_image.content }}
  </div>

  <div class="shop-card__content">
    <div class="shop-card__meta">
      <span class="shop-card__pet-type">{{ fields.field_pet_type.content|striptags|trim }}</span>
      <h3 class="shop-card__title">
        <a href="{{ product_url }}">{{ fields.title.content|striptags|trim }}</a>
      </h3>
    </div>
    <div class="shop-card__footer">
      <div class="shop-card__price-wrap">
        <span class="shop-card__price">${{ fields.field_price.content|striptags|trim }}</span>
      </div>
      <a href="{{ product_url }}" class="shop-card__add" aria-label="Ver produto">+</a>
    </div>
  </div>

</article>

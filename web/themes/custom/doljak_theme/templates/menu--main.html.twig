{% import _self as menus %}

<div class="site-header__menu-panel">
  <div class="site-header__menu-heading" aria-hidden="true">
    <span class="site-header__menu-eyebrow">Menu</span>
    <span class="site-header__menu-title">Browse Waggy</span>
  </div>

  {{ menus.menu_links(items, attributes, 0) }}

  <a class="site-header__menu-cta" href="/shop">
    <span class="site-header__menu-cta-label site-header__menu-cta-label--tablet">Explore the catalog</span>
    <span class="site-header__menu-cta-label site-header__menu-cta-label--mobile">View all products</span>
  </a>
</div>

{% macro menu_links(items, attributes, menu_level) %}
  {% import _self as menus %}
  {% if items %}
    {% if menu_level == 0 %}
      <ul{{ attributes }}>
    {% else %}
      <ul>
    {% endif %}
    {% for item in items %}
      <li{{ item.attributes }}>
        {{ link(item.title, item.url) }}
        {% if item.below %}
          {{ menus.menu_links(item.below, attributes, menu_level + 1) }}
        {% endif %}
      </li>
    {% endfor %}
      </ul>
  {% endif %}
{% endmacro %}

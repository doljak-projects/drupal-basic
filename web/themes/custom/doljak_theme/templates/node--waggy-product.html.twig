  'dogs': [
    { pet: 'Dogs', type: 'dogs', badge: 'Best', title: 'Comfort Pet Harness', price: '49', image: '/sites/default/files/produtos/comfort-pet-harness.jpg' },
    { pet: 'Dogs', type: 'dogs', badge: 'Hot', title: 'Retractable Leash Pro', price: '36', image: '/sites/default/files/produtos/retractable-leash-pro.jpg' },
    { pet: 'Dogs', type: 'dogs', badge: 'New', title: 'Waterproof Dog Bed', price: '72', image: '/sites/default/files/produtos/waterproof-dog-bed.jpg' },
    { pet: 'Dogs', type: 'dogs', badge: 'Best', title: 'Dog Chew Toy Bone', price: '18', image: '/sites/default/files/produtos/dog-chew-toy-bone.jpg' }
  ],
  'cats': [
    { pet: 'Cats', type: 'cats', badge: 'New', title: 'Cat Scratching Post', price: '64', image: '/sites/default/files/produtos/cat-scratching-post.jpg' },
    { pet: 'Cats', type: 'cats', badge: 'Best', title: 'Automatic Cat Feeder', price: '84', image: '/sites/default/files/produtos/automatic-cat-feeder.jpg' },
    { pet: 'Cats', type: 'cats', badge: 'Hot', title: 'Window Perch Bed', price: '42', image: '/sites/default/files/produtos/window-perch-bed.jpg' },
    { pet: 'Cats', type: 'cats', badge: 'Best', title: 'Catnip Toy Bundle', price: '19', image: '/sites/default/files/produtos/catnip-toy-bundle.jpg' }
  ],
  'birds': [
    { pet: 'Birds', type: 'birds', badge: 'Best', title: 'Travel Bird Cage', price: '89', image: '/sites/default/files/produtos/travel-bird-cage.jpg' },
    { pet: 'Birds', type: 'birds', badge: 'New', title: 'Wooden Bird Perch', price: '21', image: '/sites/default/files/produtos/wooden-bird-perch.jpg' },
    { pet: 'Birds', type: 'birds', badge: 'Hot', title: 'Feather Rope Toy', price: '16', image: '/sites/default/files/produtos/feather-rope-toy.jpg' },
    { pet: 'Birds', type: 'birds', badge: 'Best', title: 'Colorful Swing Toy', price: '18', image: '/sites/default/files/produtos/colorful-swing-toy.jpg' }
  ],
  'fish': [
    { pet: 'Fish', type: 'fish', badge: 'Best', title: 'Tropical Fish Food', price: '17', image: '/sites/default/files/produtos/tropical-fish-food.jpg' },
    { pet: 'Fish', type: 'fish', badge: 'Hot', title: 'Aquarium Filter Pro', price: '68', image: '/sites/default/files/produtos/aquarium-filter-pro.jpg' },
    { pet: 'Fish', type: 'fish', badge: 'New', title: 'Decorative Coral Set', price: '29', image: '/sites/default/files/produtos/decorative-coral-set.jpg' },
    { pet: 'Fish', type: 'fish', badge: 'Best', title: 'LED Tank Light', price: '52', image: '/sites/default/files/produtos/led-tank-light.jpg' }
  ],
  'small-pets': [
    { pet: 'Small Pets', type: 'small-pets', badge: 'Best', title: 'Wooden Hideout House', price: '44', image: '/sites/default/files/produtos/wooden-hideout-house.jpg' },
    { pet: 'Small Pets', type: 'small-pets', badge: 'Hot', title: 'Exercise Ball Large', price: '22', image: '/sites/default/files/produtos/exercise-ball-large.jpg' },
    { pet: 'Small Pets', type: 'small-pets', badge: 'New', title: 'Hamster Wheel Silent', price: '31', image: '/sites/default/files/produtos/hamster-wheel-silent.jpg' },
    { pet: 'Small Pets', type: 'small-pets', badge: 'Best', title: 'Hay Bedding Mix', price: '26', image: '/sites/default/files/produtos/hay-bedding-mix.jpg' }
  ]
} %}
{% set related_cards = related_catalog[pet_type_slug]|default(related_catalog['dogs']) %}
{% set section_tags = hero_content.tags|merge([pet_type_label ~ ' essentials', 'Paper-inspired layout']) %}

<article{{ attributes.addClass('product-detail', 'product-detail--' ~ pet_type_slug) }}>
  <section class="product-detail__hero">
    <div class="product-detail__hero-inner">
      <div class="product-detail__content">
        <div class="product-detail__breadcrumbs">
          <a href="{{ path('<front>') }}">Home</a>
          <span>/</span>
          <a href="/shop">Shop</a>
          <span>/</span>
          <a href="/shop/{{ pet_type_slug }}">{{ pet_type_label }}</a>
        </div>

        <span class="product-detail__eyebrow">{{ hero_content.eyebrow }}</span>
        {{ title_prefix }}
        <h1 class="product-detail__title">{{ product_title }}</h1>
        {{ title_suffix }}

        <div class="product-detail__price-row">
          <span class="product-detail__price">${{ price_raw }}</span>
          <span class="product-detail__price-compare">Premium pick for calmer daily routines</span>
          <span class="product-detail__review">4.9 from 1.2k happy pet homes</span>
        </div>

        <p class="product-detail__summary">{{ hero_content.summary }}</p>

        <div class="product-detail__chips">
          {% for tag in hero_content.tags %}
            <span class="product-detail__chip">{{ tag }}</span>
          {% endfor %}
        </div>

        <ul class="product-detail__bullet-list">
          {% for bullet in hero_content.bullets %}
            <li>{{ bullet }}</li>
          {% endfor %}
        </ul>

        <div class="product-detail__actions">
          <a class="product-detail__button product-detail__button--primary" href="#purchase-support">Add To Cart</a>
          <a class="product-detail__button product-detail__button--ghost" href="#product-specs">
            <span class="product-detail__button-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M5 12H19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <path d="M12 5L19 12L12 19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            See Details
          </a>
        </div>

        <div class="product-detail__stats">
          <div class="product-detail__stat-card">
            <strong>14d</strong>
            <span>Easy-repeat routine</span>
          </div>
          <div class="product-detail__stat-card">
            <strong>4.9</strong>
            <span>Average customer rating</span>
          </div>
          <div class="product-detail__stat-card">
            <strong>Free</strong>
            <span>Shipping over $45</span>
          </div>
        </div>
      </div>

      <div class="product-detail__media-column">
        <div class="product-detail__media-backdrop" aria-hidden="true"></div>
        <div class="product-detail__media-card">
          {% if badge_text is not empty %}
            <span class="product-detail__hero-badge">{{ badge_text }}</span>
          {% endif %}

          <div class="product-detail__image-wrap">
            {% if image_url %}
              <img src="{{ image_url }}" alt="{{ product_title }}" class="product-detail__image">
            {% else %}
              <div class="product-detail__image-fallback">{{ product_title }}</div>
            {% endif %}
          </div>

          <div class="product-detail__media-footer">
            <div>
              <span class="product-detail__media-label">{{ pet_type_label }}</span>
              <p>{{ hero_content.descriptor }}</p>
            </div>
            <a href="#purchase-support" class="product-detail__media-cta" aria-label="Ir para compra">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
                <path d="M5 12H19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                <path d="M12 5L19 12L12 19" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="product-detail__benefits">
    <div class="product-detail__section-inner">
      <div class="product-detail__section-intro">
        <div class="product-detail__section-heading">
          <span class="product-detail__eyebrow">Why It Works</span>
          <h2>Paper-style highlights that make the product page feel premium fast.</h2>
        </div>
        <p>This section is mocked intentionally to hold the composition while richer product fields are still absent from the Twig context.</p>
      </div>

      <div class="product-detail__benefit-grid">
        {% for card in feature_cards %}
          <article class="product-detail__benefit-card product-detail__benefit-card--{{ card.tone }}">
            <span class="product-detail__icon-square" aria-hidden="true"></span>
            <h3>{{ card.title }}</h3>
            <p>{{ card.body }}</p>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="product-detail__specs" id="product-specs">
    <div class="product-detail__section-inner product-detail__section-inner--specs">
      <article class="product-detail__spec-card product-detail__spec-card--warm">
        <span class="product-detail__eyebrow">Snapshot</span>
        <h2>Product Makeup</h2>
        <ul class="product-detail__line-list">
          {% for row in ingredient_rows %}
            <li><span>{{ row }}</span><strong>Included</strong></li>
          {% endfor %}
        </ul>
      </article>

      <article class="product-detail__spec-card product-detail__spec-card--blue">
        <span class="product-detail__eyebrow">Care Guide</span>
        <h2>How To Use</h2>
        <ul class="product-detail__copy-list">
          {% for row in feeding_rows %}
            <li>{{ row }}</li>
          {% endfor %}
        </ul>
      </article>

      <article class="product-detail__spec-card product-detail__spec-card--pink">
        <span class="product-detail__eyebrow">Bundles & Sizes</span>
        <h2>Pick Your Format</h2>
        <ul class="product-detail__line-list">
          {% for row in size_rows %}
            <li><span>{{ row.label }}</span><strong>{{ row.value }}</strong></li>
          {% endfor %}
        </ul>
        <a href="#purchase-support" class="product-detail__spec-link">Subscribe & Save 10%</a>
      </article>
    </div>
  </section>

  <section class="product-detail__support" id="purchase-support">
    <div class="product-detail__section-inner product-detail__section-inner--support">
      <div class="product-detail__support-copy">
        <span class="product-detail__support-eyebrow">Purchase Support</span>
        <h2>Styled for conversion now, flexible enough for real product data later.</h2>
        <p>The layout keeps the dark support band from the Paper artboard so the lower half of the product page has a stronger anchor and clearer call to action.</p>
        <a href="/shop" class="product-detail__support-button">Continue Shopping</a>
      </div>

      <div class="product-detail__support-grid">
        {% for card in support_cards %}
          <article class="product-detail__support-card">
            <span class="product-detail__support-icon" aria-hidden="true"></span>
            <h3>{{ card.title }}</h3>
            <p>{{ card.body }}</p>
          </article>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="product-detail__story">
    <div class="product-detail__section-inner product-detail__section-inner--story">
      <div class="product-detail__story-copy">
        <span class="product-detail__eyebrow">Product Description</span>
        <h2>{{ hero_content.description_heading }}</h2>
        <p>{{ hero_content.description_copy }}</p>
      </div>

      <div class="product-detail__tags-panel">
        <span class="product-detail__eyebrow">Tags</span>
        <div class="product-detail__tag-list">
          {% for tag in section_tags %}
            <span class="product-detail__tag">{{ tag }}</span>
          {% endfor %}
        </div>
      </div>
    </div>
  </section>

  <section class="product-detail__related">
    <div class="product-detail__section-inner">
      <div class="product-detail__related-head">
        <div>
          <span class="product-detail__eyebrow">Related Products</span>
          <h2>Keep the same tone across the rest of the catalog.</h2>
        </div>
        <div class="product-detail__related-nav" aria-hidden="true">
          <span class="product-detail__nav-button product-detail__nav-button--ghost">&larr;</span>
          <span class="product-detail__nav-button">&rarr;</span>
        </div>
      </div>

      <div class="product-detail__related-grid">
        {% for card in related_cards %}
          {% set related_slug = card.title|lower|replace({' ': '-'}) %}
          <article class="shop-card shop-card--{{ card.type }}">
            <a href="/shop/{{ card.type }}/{{ related_slug }}">
              <div class="shop-card__image-wrap">
                <span class="shop-card__badge">{{ card.badge }}</span>
                <img src="{{ card.image }}" alt="{{ card.title }}">
              </div>
            </a>

            <div class="shop-card__content">
              <div class="shop-card__meta">
                <span class="shop-card__pet-type">{{ card.pet }}</span>
                <h3 class="shop-card__title">
                  <a href="/shop/{{ card.type }}/{{ related_slug }}">{{ card.title }}</a>
                </h3>
              </div>
              <div class="shop-card__footer">
                <div class="shop-card__price-wrap">
                  <span class="shop-card__price">${{ card.price }}</span>
                </div>
                <a href="/shop/{{ card.type }}/{{ related_slug }}" class="shop-card__add" aria-label="Ver {{ card.title }}">+</a>
              </div>
            </div>
          </article>
        {% endfor %}
      </div>

      <div class="product-detail__pager" aria-hidden="true">
        <span class="product-detail__pager-dot is-active"></span>
        <span class="product-detail__pager-dot"></span>
        <span class="product-detail__pager-dot"></span>
      </div>
    </div>
  </section>
</article>

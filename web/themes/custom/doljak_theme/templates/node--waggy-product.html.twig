{% set pet_type_entity = node.field_pet_type.entity ?? null %}
{% set pet_type_name = pet_type_entity and pet_type_entity.name.value ? pet_type_entity.name.value : 'Dogs' %}
{% set pet_type_slug = pet_type_name|lower|replace({' ': '-'}) %}
{% set pet_type_label = pet_type_name|replace({'-': ' '})|title %}
{% set price_raw = node.field_price.value ?: '49' %}
{% set badge_text = node.field_product_badge.value ?: 'New' %}
{% set product_title = label|render|striptags|trim %}
{% set media_entity = node.field_product_image.entity ?? null %}
{% set image_file = media_entity and media_entity.field_media_image.entity ? media_entity.field_media_image.entity : null %}
{% set image_uri = image_file and image_file.uri.value ? image_file.uri.value : '' %}
{% set image_url = image_uri ? file_url(image_uri) : '' %}
{% set hero_catalog = {
  'dogs': {
    eyebrow: 'Daily Nutrition',
    summary: 'Built for fuller bowls, calmer routines, and a premium daily ritual that still feels playful.',
    bullets: ['Soft on sensitive stomachs and easy to portion.', 'Balanced textures made for everyday use.', 'Pairs naturally with bowls, treats, and at-home routines.'],
    tags: ['Protein-rich', 'Daily staple', 'Vet-friendly'],
    description_heading: 'Dog-first essentials with a softer premium finish.',
    description_copy: 'This layout mirrors the Paper direction with a more editorial rhythm: stronger hierarchy, calmer spacing, and product storytelling that feels premium without looking heavy.',
    descriptor: 'Fuel better walks, calmer mornings, and a more polished everyday feeding routine.'
  },
  'cats': {
    eyebrow: 'Play & Scratch',
    summary: 'Designed for tidy corners, daily play rituals, and that elevated at-home comfort cat parents actually keep visible.',
    bullets: ['Keeps texture, comfort, and form in balance.', 'Easy to place in modern interiors without clutter.', 'Supports the small daily habits pets repeat most.'],
    tags: ['Calming', 'Indoor ready', 'Play ritual'],
    description_heading: 'Cat comfort, styled with a cleaner editorial flow.',
    description_copy: 'The Paper composition leans into soft surfaces, airy negative space, and a premium retail tone. This rebuild keeps that direction while adapting to the current Drupal data shape.',
    descriptor: 'Make scratching, resting, and everyday play feel intentional instead of purely functional.'
  },
  'birds': {
    eyebrow: 'Habitat Essentials',
    summary: 'A lighter, cleaner presentation for perches, habitat pieces, and all the little routines that keep the enclosure feeling active.',
    bullets: ['Built around quick upkeep and daily refresh cycles.', 'Soft color balance keeps the page light and breathable.', 'Works for accessories, treats, and habitat add-ons alike.'],
    tags: ['Perch ready', 'Habitat care', 'Lightweight'],
    description_heading: 'Bird essentials with more air, pace, and clarity.',
    description_copy: 'The visual rhythm follows the Paper artboard: lighter cards, rounder silhouettes, and denser information blocks balanced by generous spacing.',
    descriptor: 'Support cleaner habitats, lighter upkeep, and a more curated accessory mix.'
  },
  'fish': {
    eyebrow: 'Tank Wellness',
    summary: 'Structured for filter care, feeding products, and tank upgrades that need to feel technical without becoming cold or clinical.',
    bullets: ['Keeps technical details readable at a glance.', 'Soft pastels avoid the typical sterile aquarium UI feel.', 'Easy to extend later with real specs and comparison tables.'],
    tags: ['Tank care', 'Water-safe', 'Routine upgrade'],
    description_heading: 'Aquatic care with warmer styling and clearer product focus.',
    description_copy: 'The Paper version mixes soft retail polish with a more system-like structure. This HTML rebuild keeps those signals while using mock content where the node is still thin.',
    descriptor: 'Bring more warmth and clarity to the products that keep the tank stable every day.'
  },
  'small-pets': {
    eyebrow: 'Cozy Living',
    summary: 'Made for hideouts, bedding, toys, and daily habitat comforts with a softer palette and a more giftable presentation.',
    bullets: ['Balances function and softness for compact habitats.', 'Makes supportive details easier to scan for pet parents.', 'Works well for accessories, bedding, and enrichment items.'],
    tags: ['Habitat cozy', 'Soft comfort', 'Daily enrichment'],
    description_heading: 'Small-pet pieces that feel warmer, calmer, and more considered.',
    description_copy: 'The sectioning follows the Paper board closely: expressive hero, modular benefit cards, rounded data panels, and a warmer support block that anchors the bottom of the page.',
    descriptor: 'Turn compact habitats into calmer, more comfortable daily spaces.'
  }
} %}
{% set hero_content = hero_catalog[pet_type_slug]|default(hero_catalog['dogs']) %}
{% set feature_cards = [
  { tone: 'warm', title: 'Everyday Comfort', body: 'Rounded layouts, softer spacing, and a premium surface treatment keep the product story feeling calm.' },
  { tone: 'blue', title: 'Clear Product Cues', body: 'Pricing, badges, benefits, and utility links are separated cleanly so the page reads faster.' },
  { tone: 'green', title: 'Routine-Friendly', body: 'The structure supports daily-use products especially well, even before richer backend fields arrive.' },
  { tone: 'pink', title: 'Paper-Led Styling', body: 'Large curves, editorial headings, and layered pastels keep the page close to the design direction.' }
] %}
{% set ingredient_rows = ['Premium material blend', 'Easy-care finish', 'Soft-touch construction', 'Daily routine friendly'] %}
{% set feeding_rows = ['Use daily as part of a calm routine.', 'Pair with the matching essentials in shop.', 'Refresh or replace as needed for best comfort.', 'Store in a clean, dry, easy-access spot.'] %}
{% set size_rows = [
  { label: 'Starter pick', value: 'Best for first-time buyers' },
  { label: 'Most loved', value: 'Balanced size for daily use' },
  { label: 'Bundle ready', value: 'Pairs well with matching add-ons' }
] %}
{% set support_cards = [
  { title: 'Free shipping on curated orders', body: 'Orders above $45 stay light, easy, and shipping-friendly.' },
  { title: 'Care notes that feel human', body: 'Simple guidance blocks make upkeep easier to understand.' },
  { title: 'Thoughtful add-on pairing', body: 'Cross-sell moments feel styled instead of forced.' },
  { title: 'Ready for richer data later', body: 'Mock sections can be swapped for real fields without redoing the layout.' }
] %}

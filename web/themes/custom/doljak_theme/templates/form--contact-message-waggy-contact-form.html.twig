{{ attach_library('doljak_theme/contact') }}
<section class="contact-page">
  <div class="contact-page__inner">
    <div class="contact-page__hero">
      <span class="contact-page__eyebrow">Contact Waggy</span>
      <h1 class="contact-page__headline">Let us know what your pet needs.</h1>
      <p class="contact-page__description">
        Questions about orders, product guidance or routines. Fill the form and the team gets back within one business day.
      </p>

      <div class="contact-page__stats" aria-label="Support details">
        <div class="contact-page__stat contact-page__stat--warm">
          <strong>1 day</strong>
          <span>average reply on business days</span>
        </div>
        <div class="contact-page__stat contact-page__stat--soft">
          <strong>Real team</strong>
          <span>orders, returns and care support</span>
        </div>
      </div>

      <p class="contact-page__meta">Monday to Friday · 9am to 6pm</p>
      <p class="contact-page__note">For urgent order issues, include your order number in the subject.</p>
    </div>

    <div class="contact-page__card">
      <div class="contact-page__card-header">
        <h2 class="contact-page__card-title">Contact</h2>
        <p class="contact-page__card-subtitle">Use the same Drupal fields from the page with a layout aligned to the Waggy design system.</p>
      </div>

      <form{{ attributes.addClass('contact-page__form') }}>
        {{ children }}
      </form>
    </div>
  </div>
</section>

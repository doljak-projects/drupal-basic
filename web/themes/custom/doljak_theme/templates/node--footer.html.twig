{#
  node--footer.html.twig
  Estrutura compartilhada do footer para fallback global no tema e para uso
  futuro em um bloco ou node dedicado, caso a região de footer passe a ser
  gerenciada pelo Drupal Admin.
#}

<section{{ attributes.addClass('footer-content') }}>
  {% include '@doljak_theme/includes/footer-content.html.twig' with {
    footer_front_page: path('<front>'),
    footer_brand_primary: 'Waggy',
    footer_brand_secondary: 'Pet shop.',
    footer_body: content.body is not empty ? content.body : null,
    footer_columns: footer_columns ?? [],
    footer_social_links: footer_social_links ?? [],
    footer_newsletter_title: footer_newsletter_title ?? 'Our Newsletter',
    footer_newsletter_copy: footer_newsletter_copy ?? 'Subscribe to our newsletter to get updates about our grand offers.',
    footer_newsletter_placeholder: 'Enter your email-address',
    footer_email_id: 'footer-content-email',
    footer_legal: '©' ~ 'now'|date('Y') ~ ' Waggy. All rights reserved.',
    footer_credit: 'Template design by: Templates Jungle'
  } only %}
</section>

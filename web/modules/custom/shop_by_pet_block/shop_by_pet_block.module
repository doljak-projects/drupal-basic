<?php

/**
 * Implements hook_theme().
 */
function shop_by_pet_block_theme() {
  return [
    'shop_by_pet_block' => [
      'variables' => [],
      'template' => 'shop-by-pet-block',
      'path' => \Drupal::service('extension.list.module')->getPath('shop_by_pet_block') . '/templates',
    ],
  ];
}